{
  "name": "@l2beat/interop-backoffice",
  "version": "0.1.0",
  "private": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf build",
    "format:fix": "biome format --write .",
    "build:dependencies": "cd ../.. && pnpm build:dependencies:interop-backoffice",
    "watch:dependencies": "cd ../.. && pnpm watch:dependencies:interop-backoffice",
    "format": "biome format .",
    "lint:fix": "biome check --formatter-enabled=false --write .",
    "lint": "biome check --formatter-enabled=false .",
    "test": "mocha",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@l2beat/database": "workspace:*",
    "@l2beat/typescript-config": "workspace:*",
    "@trpc/server": "^11.0.0-rc.446",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "koa": "^2.14.1",
    "@types/koa": "^2.13.5",
    "@l2beat/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.6",
    "dotenv": "^17.2.3",
    "earl": "^1.1.0",
    "mocha": "^10.2.0"
  }
}
