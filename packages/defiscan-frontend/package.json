{
  "name": "@l2beat/defiscan-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf build",
    "compile-data": "tsx scripts/compile-data.ts",
    "prebuild": "pnpm clean && pnpm compile-data",
    "build": "vite build",
    "preview": "vite preview",
    "dev": "pnpm compile-data && vite",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome check --formatter-enabled=false .",
    "lint:fix": "biome check --formatter-enabled=false --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@tanstack/react-query": "^5.59.16",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@l2beat/typescript-config": "workspace:*",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "vite": "^5.4.10"
  }
