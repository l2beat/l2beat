    "eth:0xef9Dc1F87BAA090a35B985DAad9c8096440F2012": "FluentEnclaveAttesterEOA"
  },
  "overrides": {
    "eth:0x1cF53Fd9CD0b713be29F2b41cA17A943f138727f": {
      // FluentRollup proxy - ignore per-batch lookups (unbounded arrays)
      "ignoreMethods": [
        "batchBlobHashes",
        "batchChallengedBlocks",
        "batchProvenBlocks",
        "blockChallengeQueueAt",
        "getBatch",
        "getBatchRootChallenge",
        "isBatchFinalized",
        "isBatchPreconfirmed",
        "proxiableUUID"
      ]
    },
    "eth:0x9CAcf613fC29015893728563f423fD26dCdB8Ddc": {
      // L1FluentBridge proxy - ignore per-message lookups
      "ignoreMethods": ["getMessageAt", "proxiableUUID"]
    },
    "eth:0x8976Ca4E0c8467097Da675399fB7DB454a1b56dd": {
      "ignoreMethods": ["proxiableUUID"]
    },
    "eth:0xFD4C62647A34FF6d6802092F5fbe176099223B61": {
