  "initialAddresses": [
    "eth:0x1cF53Fd9CD0b713be29F2b41cA17A943f138727f", // Rollup proxy
    "eth:0x9CAcf613fC29015893728563f423fD26dCdB8Ddc", // FluentBridge proxy
