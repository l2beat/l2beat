            "date": "2026-04-17T09:00:32.092Z"
          }
        },
        {
          "functionName": "_setVotingDelay",
          "isPermissioned": true,
          "checked": true,
          "score": "no-impact",
          "description": "Sets the number of blocks between proposal creation and the start of voting. When called via the GovernorBravoDelegator (proxy), the admin check resolves against the proxy's `admin` slot — currently the 48h Timelock — so this is a Timelock-controlled parameter, not a renounced one. Bounded on-chain to MIN_VOTING_DELAY ≤ value ≤ MAX_VOTING_DELAY.",
          "ownerDefinitions": [
            {
              "path": "eth:0x408ED6354d4973f66138C91495F2f2FCbd8724C3.admin"
