          }
        },
        {
          "functionName": "_setVotingPeriod",
          "isPermissioned": true,
          "checked": true,
          "score": "no-impact",
          "description": "Sets the duration of the voting window in blocks. When called via the GovernorBravoDelegator (proxy), the admin check resolves against the proxy's `admin` slot — currently the 48h Timelock — so changes go through standard governance. Bounded on-chain to MIN_VOTING_PERIOD ≤ value ≤ MAX_VOTING_PERIOD.",
