      "functions": [
        {
          "functionName": "initialize",
          "isPermissioned": true,
          "checked": true,
          "score": "no-impact",
          "description": "Implementation-side initializer for the GovernorBravo logic contract. Reverts unless `initialProposalId == 0`, which the deployed delegator already advanced past during initial setup, so it can never be re-run on the live proxy. Storage and msg.sender checks resolve against the GovernorBravoDelegator (proxy) when invoked via delegatecall — not against the inert implementation slots that read as the zero address.",
          "ownerDefinitions": [
            {
              "path": "eth:0x408ED6354d4973f66138C91495F2f2FCbd8724C3.admin"
