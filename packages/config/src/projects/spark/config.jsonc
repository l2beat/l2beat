{
  "$schema": "../../../../discovery/schemas/config.v2.schema.json",
  "name": "spark",
  "import": ["../globalConfig.jsonc"],
  "maxDepth": 7,
  "initialAddresses": [
    "eth:0x02C3eA4e34C0cBd694D2adFa2c690EECbC1793eE",
    "eth:0x3300f198988e4C9C63F75dF86De36421f06af8c4",
