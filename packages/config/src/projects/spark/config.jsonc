    // --- Kelp LRTOracle (RSETHExchangeRateOracle.oracle): leaf — ignore lrtConfig so Kelp's stack stays out ---
    // --- Also surface Spark's rsETH pool balance so dependency impactCap auto-tracks on-chain state ---
    "eth:0x349A73444b1a310BAe67ef67973022020d70020d": {
      "ignoreRelatives": ["$admin", "$implementation", "admin", "implementation", "owner", "lrtConfig"],
      "fields": {
        // Any Kelp compromise (LRTOracle manipulation, rsETH exchange rate fraud) can only
        // affect Spark's lending pool up to the rsETH held by Spark's rsETH AToken. Over-
        // valuing rsETH lets attackers over-borrow against it (drain other assets up to
        // rsETH-collateral-value × LTV); under-valuing unfairly liquidates rsETH positions.
        // Both paths are bounded by the pool's rsETH balance.
        "sparkRsETHPoolBalance": {
          "description": "rsETH balance of Spark's rsETH AToken (0x856f1Ea7...). Bounds the impact of Kelp oracle manipulation since all Kelp oracle calls into Spark go through rsETH-collateralized positions.",
          "handler": {
            "type": "call",
            "method": "function balanceOf(address) view returns (uint256)",
            "args": ["0x856f1Ea78361140834FDCd0dB0b08079e4A45062"],
            "address": "eth:0xA1290d69c65A6Fe4DF752f95823fae25cB99e5A7"
          }
        }
      },
      "ignoreInWatchMode": [
        "getCurrentPeriodStartTime",
        "getNextDailyLimitResetTimestamp"
      ]
    },
