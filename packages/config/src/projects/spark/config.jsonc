    // --- Leaf: Maker MedianGNOUSD (slot mapping drags Chronicle-style feeders) ---
    "eth:0x31BFA908637C29707e155Cfac3a50C9823bF8723": {
      "ignoreRelatives": ["slot"]
    },
    // --- Leaf: MakerDAO Pot (vat/vow are Maker core) ---
    "eth:0x197E90f9FAD81970bA7976f33CbD77088E5D7cf7": {
      "ignoreRelatives": [
        "vat",
        "vow"
      ],
      "ignoreInWatchMode": [
        "Pie",
        "chi",
        "rho"
      ]
    },
    // --- Spark: EmissionManager — surface per-reward emission admin via EmissionAdminUpdated events ---
    // --- and the Rewards Vault's live wstETH balance so reward-system impact caps auto-track on-chain state ---
    "eth:0xf09e48dd4CA8e76F63a57ADd428bB06fee7932a4": {
      "fields": {
        "emissionAdmins": {
          "handler": {
            "type": "event",
            "select": "newAdmin",
            "groupBy": "reward",
            "set": { "event": "event EmissionAdminUpdated(address indexed reward, address indexed oldAdmin, address indexed newAdmin)" }
          }
        },
        // Reward distribution uses PullRewardsTransferStrategy (0x11aAC1cA..) which calls
        // wstETH.transferFrom(vault, user, amount) on each claim, so the absolute maximum
        // drainable via any reward-system compromise is bounded by the Vault's wstETH balance.
        // Vault = 2/3 Safe (0x8076...), which is also the emission admin for wstETH.
        "rewardsVaultWstETHBalance": {
          "description": "wstETH balance of the Rewards Vault (2/3 Safe 0x8076807464DaC94Ac8Aa1f7aF31b58F73bD88A27). Used as the impactCap upper bound for reward-system admin functions since PullRewardsTransferStrategy pulls rewards from this vault via transferFrom.",
          "handler": {
            "type": "call",
            "method": "function balanceOf(address) view returns (uint256)",
            "args": ["0x8076807464DaC94Ac8Aa1f7aF31b58F73bD88A27"],
            "address": "eth:0x7f39C581F595B53c5cb19bD0b3f8dA6c935E2Ca0"
          }
        }
      },
      "ignoreInWatchMode": [
        "rewardsVaultWstETHBalance"
      ]
    },
    "eth:0x9Ad87668d49ab69EEa0AF091de970EF52b0D5178": {
      "fields": {
        "accessControl": {
          "handler": {
            "type": "accessControl",
            "roleNames": {
              "0x70546d1c92f8c2132ae23a23f5177aa8526356051c7510df99f50e012d221529": "CONTROLLER",
              "0x0ac42a08299cbc4428ec38ad4a8e7d7440779fbbb20ea90bd10c094a406cfa6f": "FREEZER"
            }
          }
        }
      }
    },
