    // --- Renzo RestakeManager (EZETHExchangeRateOracle.oracle): leaf — ignore every internal ref so Renzo's stack stays out ---
    "eth:0x74a09653A083691711cF8215a6ab074BB4e99ef5": {
      "ignoreRelatives": [
