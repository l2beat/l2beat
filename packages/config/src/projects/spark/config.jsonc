    "eth:0xBE8E3e3618f7474F8cB1d074A26afFef007E98FB",
    "eth:0xc20059e0317DE91738d13af027DfC4a50781b066"
  ],
  "overrides": {
    "eth:0x3300f198988e4C9C63F75dF86De36421f06af8c4": {
      "fields": {
        "wards": {
          "handler": {
            "type": "event",
            "select": "usr",
            "add": { "event": "event Rely(address indexed usr)" },
            "remove": { "event": "event Deny(address indexed usr)" }
          }
        }
      }
    },
    "eth:0xdA135Cd78A086025BcdC87B038a1C462032b510C": {
      "fields": {
        "accessControl": {
          "handler": {
            "type": "accessControl",
            "roleNames": {
              "0x12ad05bde78c5ab75238ce885307f96ecd482bb402ef831f99e7018a0f169b7b": "POOL_ADMIN_ROLE",
              "0x5c91514091af31f62f596a314af7d5be40146b2f2355969392f055e12e0982fb": "EMERGENCY_ADMIN_ROLE",
              "0x8aa855a911518ecfbe5bc3088c8f3dda7badf130faaf8ace33fdc33828e18167": "RISK_ADMIN_ROLE",
              "0x939b8dfb57ecef2aea54a93a15e86768b9d4089f1ba61c245e6ec980695f4ca4": "FLASH_BORROWER_ROLE",
              "0x08fb31c3e81624356c3314088aa971b73bcc82d22bc3e3b184b4593077ae3278": "BRIDGE_ROLE",
              "0x19c860a63258efbd0ecb7d55c626237bf5c2044c26c073390b74f0c13c857433": "ASSET_LISTING_ADMIN_ROLE"
            }
          }
        }
      }
    },
    "eth:0x4C1341636721b8B687647920B2E9481f3AB1F2eE": {
      "fields": { "accessControl": { "handler": { "type": "accessControl" } } }
    },
    "eth:0xC13e21B648A5Ee794902342038FF3aDAB66BE987": {
      "fields": { "constructorArgs": { "handler": { "type": "constructorArgs", "nameArgs": true } } }
    },
    "eth:0x542DBa469bdE58FAeE189ffB60C6b49CE60E0738": {
      "fields": { "constructorArgs": { "handler": { "type": "constructorArgs", "nameArgs": true } } }
    },
    // --- Spark: AaveOracle — surface per-asset price source map (may be direct Chainlink EAC or a Spark ratio oracle that combines two feeds) ---
    "eth:0x8105f69D9C41644c6A0803fDA7D03Aa70996cFD9": {
      "fields": {
        "assetSources": {
          "handler": {
            "type": "event",
            "select": "source",
            "groupBy": "asset",
            "set": { "event": "event AssetSourceUpdated(address indexed asset, address indexed source)" }
          }
        }
      }
    },
    // --- Spark oracle wrappers: keep visible as leaves, prune feed references to avoid Chronicle/Renzo/Kelp/Lido contagion ---
    "eth:0xE98d51fa014C7Ed68018DbfE6347DE9C3f39Ca39": {
      "ignoreRelatives": [
        "steth"
      ],
      "ignoreInWatchMode": [
        "latestAnswer"
      ]
    },
    // EZETHExchangeRateOracle, RSETHExchangeRateOracle: let `oracle` (Renzo/Kelp) be discovered as dep; leaf prunes below
    // --- Chronicle Aggors: let feeds be discovered as leaves (leaf overrides below prune each) ---
    // --- SavingsDaiOracle, Fig, CLSynchronicityPriceAdapterPegToBase: same — let references land, prune at each leaf ---

    // --- Leaf: Chainlink main aggregators (same shape as existing 3 EACs) ---
    "eth:0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419": {
      "ignoreRelatives": ["owner", "aggregator", "accessController", "proposedAggregator"]
    },
    "eth:0xF4030086522a5bEEa4988F8cA5B36dbC97BeE88c": {
      "ignoreRelatives": ["owner", "aggregator", "accessController", "proposedAggregator"]
    },
    // --- Leaf: Chronicle core oracles (authed/feeds/tolled pull full Chronicle infra) ---
    "eth:0x46ef0071b1E2fF6B42d36e5A177EA43Ae5917f4E": {
      "ignoreRelatives": ["authed", "feeds", "tolled"]
    },
    "eth:0x24C392CDbF32Cf911B258981a66d5541d85269ce": {
      "ignoreRelatives": ["authed", "feeds", "tolled"]
    },
    // --- Leaf: Redstone price feeds (ERC1967 proxies) ---
    "eth:0x67F6838e58859d612E4ddF04dA396d6DABB66Dc4": {
      "ignoreRelatives": [
        "$admin",
        "$implementation",
        "admin",
        "implementation",
        "owner",
        "getPriceFeedAdapter"
      ],
      "ignoreInWatchMode": [
        "latestAnswer",
        "latestRoundData"
      ]
    },
    "eth:0xAB7f623fb2F6fea6601D4350FA0E2290663C28Fc": {
      "ignoreRelatives": [
        "$admin",
