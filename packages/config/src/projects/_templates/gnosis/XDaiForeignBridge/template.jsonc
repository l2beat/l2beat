{
  "$schema": "../../../../../../discovery/schemas/contract.v2.schema.json",
  "ignoreRelatives": [
    "sDaiToken",
    "DAI_USDS",
    "USDS",
    "daiToken",
    "erc20token",
    "DAI"
  ],
  "ignoreInWatchMode": [
    "getCurrentDay",
    "maxAvailablePerTx",
    "maxPerTx",
    "nonce"
  ],
  "fields": { "HASHI_IS_MANDATORY": { "severity": "HIGH" } },
  "ignoreMethods": [
    "totalExecutedPerDay",
    "totalSpentPerDay",
    "withinExecutionLimit",
    "withinLimit"
  ]
}
