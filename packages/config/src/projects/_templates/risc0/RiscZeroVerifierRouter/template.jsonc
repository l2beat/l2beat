      "handler": {
        "type": "call",
        "method": "function verifiers(bytes4) view returns (address)",
        "args": ["0xbb001d44"]
      }
    },
    "verifier_73c457ba": {
      "severity": "HIGH",
      "handler": {
        "type": "call",
        "method": "function verifiers(bytes4) view returns (address)",
        "args": ["0x73c457ba"]
      }
    },
    "verifier_242f9d5b": {
      "severity": "HIGH",
      "handler": {
        "type": "call",
        "method": "function verifiers(bytes4) view returns (address)",
        "args": ["0x242f9d5b"]
      }
    }
  }
}
