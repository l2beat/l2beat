{
  "$schema": "../../../../../../discovery/schemas/contract.v2.schema.json",
  "description": "A router proxy that routes to verifiers based on selectors. The mapping can be changed by a permissioned owner ({{owner}}).",
  "fields": {
    "owner": {
      "permissions": [
        {
          "type": "interact",
          "description": "add/remove verifiers and the selectors they are mapped to."
        }
      ]
    },
    // Read the verifier registered at each known selector directly from the public `verifiers`
    // mapping, so the leaf verifiers are discovered and tracked independent of the owner. Selectors
    // are maintained by hand from the owner timelock's executed addVerifier calls; an unset/removed
    // selector reads back as the zero/tombstone address and is not followed.
    "verifier_310fe598": {
      "severity": "HIGH",
      "handler": {
        "type": "call",
        "method": "function verifiers(bytes4) view returns (address)",
        "args": ["0x310fe598"]
      }
    },
    "verifier_9f39696c": {
      "severity": "HIGH",
      "handler": {
        "type": "call",
        "method": "function verifiers(bytes4) view returns (address)",
        "args": ["0x9f39696c"]
      }
    },
    "verifier_f536085a": {
      "severity": "HIGH",
      "handler": {
        "type": "call",
        "method": "function verifiers(bytes4) view returns (address)",
        "args": ["0xf536085a"]
      }
    },
    "verifier_bb001d44": {
