{
  "$schema": "../../../../../../discovery/schemas/contract.v2.schema.json",
  "category": "shared",
  "description": "Defines and stores pauser and unpauser roles for EigenLayer contracts.",
  "fields": {
    "pausers": {
      "handler": {
        "type": "event",
        "select": "pauser",
        "add": {
          "event": "PauserStatusChanged",
          "where": ["=", "#canPause", true]
        },
        "remove": {
          "event": "PauserStatusChanged",
          "where": ["!=", "#canPause", true]
        }
      },
      "permissions": [{ "type": "act" }]
    }
  }
}
