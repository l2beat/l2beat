{
  "$schema": "../../../../../../discovery/schemas/contract.v2.schema.json",
  "ignoreMethods": ["getStaticConfig"],
  "ignoreRelatives": ["getSupportedTokens", "owner"],
  "ignoreInWatchMode": ["getExpectedNextSequenceNumber"],
  "fields": {
    "staticConfig": {
      "description": "Immutable per-OnRamp config: source chain (this contract's chain), RMN remote, NonceManager, TokenAdminRegistry. Set once at construction.",
      "handler": {
        "type": "call",
        "args": [],
        "method": "getStaticConfig"
      },
      "edit": ["set", "chainSelector", ["format", "CCIPChainName"]]
    },
    "destChainConfigs": {
      "description": "Per-destination-chain lane config (which local Router can send ccipSend() for this destination, and whether the per-chain allowlist gate is enabled). Replayed from DestChainConfigSet events; keys are CCIP chain selectors, value is the latest (router, allowlistEnabled) pair. The sequenceNumber field on the event reflects the seq at the moment of the config change, not the current send counter, so it is dropped.",
      "handler": {
        "type": "event",
        "groupBy": "destChainSelector",
        "select": ["router", "allowlistEnabled"],
        "set": {
          "event": "event DestChainConfigSet(uint64 indexed destChainSelector, uint64 sequenceNumber, address router, bool allowlistEnabled)"
        }
      },
      "edit": ["map_keys", ["format", "CCIPChainName"]]
    },
    "destChainAllowlist": {
      "description": "Per-destination-chain sender allowlist (addresses that ccipSend() through this OnRamp for that destination when allowlistEnabled is true). Replayed from AllowListSendersAdded / AllowListSendersRemoved events.",
      "handler": {
        "type": "event",
        "groupBy": "destChainSelector",
        "select": "senders",
        "flatten": true,
        "add": {
          "event": "event AllowListSendersAdded(uint64 indexed destChainSelector, address[] senders)"
        },
        "remove": {
          "event": "event AllowListSendersRemoved(uint64 indexed destChainSelector, address[] senders)"
        }
      },
      "edit": ["map_keys", ["format", "CCIPChainName"]]
    }
  }
}
