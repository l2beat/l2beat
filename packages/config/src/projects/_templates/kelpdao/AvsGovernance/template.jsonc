{
  "$schema": "../../../../../../discovery/schemas/contract.v2.schema.json",
  "displayName": "AvsGovernance",
  "description": "Othentic-style AVS governance contract. Holds the AVS-wide config, accepts operator registrations, and exposes getRestakeableStrategies / stakingContracts for the entire AVS network.",
  "ignoreRelatives": [
    "EXTENSION_IMPLEMENTATION",
    "adapter",
    "adapterAddress",
    "aggregator",
    "alertConfirmer",
    "attestationCenter",
    "avsTreasury",
    "blsApkRegistry",
    "controller",
    "ejector",
    "freezeOracle",
    "getAllActiveOperators",
    "getRestakeableStrategies",
    "indexRegistry",
    "l2ChainMapping",
    "nodeRegistry",
    "nodeRegistryAddress",
    "pauserRegistry",
    "registryCoordinator",
    "restakeableStrategies",
    "rewardsInitiator",
    "signatureChecker",
    "socketRegistry",
    "stakeRegistry",
    "stakingContracts",
    "unfreezeReceiver",
    "voteWeigher"
  ]
}
