  "overrides": {
    "eth:0xA1290d69c65A6Fe4DF752f95823fae25cB99e5A7": {
      "category": "core",
      "description": "Core rsETH token contract. It mints/burns rsETH against collateral flows and enforces transfer and mint controls through the external LRTConfig authority.",
      "ignoreInWatchMode": [
        "currentPeriodMintedAmount",
        "getCurrentPeriodStartTime",
        "getNextDailyLimitResetTimestamp",
        "periodStartTime",
        "remainingDailyMintLimit",
        "totalSupply"
      ],
      "fields": {
        "$admin": {
          "severity": "HIGH",
          "type": "CODE_CHANGE",
          "description": "Proxy admin that can upgrade the rsETH implementation.",
          "permissions": [{ "type": "upgrade" }]
        },
        "lrtConfig": {
          "severity": "HIGH",
          "type": ["PERMISSION", "EXTERNAL"],
          "description": "External control plane contract used for privileged role checks (pause/mint/config operations).",
          "permissions": [
            {
              "type": "interact",
              "description": "control privileged rsETH operations by changing role assignments and role-gated configuration in LRTConfig."
            }
          ]
        },
        "custodyAddress": {
          "severity": "HIGH",
          "type": "PERMISSION",
          "description": "Custody safe used in rsETH mint/redeem settlement flows.",
          "permissions": [
            {
              "type": "interact",
              "description": "control custody-side settlement operations for rsETH minting and redemptions."
            }
          ]
        },
        "maxMintAmountPerDay": {
          "severity": "HIGH",
          "type": "RISK_PARAMETER",
          "description": "Daily mint cap controlling maximum rsETH issuance in a period."
        },
        "$tokenData": {
          "handler": {
            "type": "ERC20Data",
            "overrides": {
              "source": "external",
              "supply": "totalSupply",
              "category": "ether",
              "coingeckoId": "kelp-dao-restaked-eth"
            }
          }
        }
      }
    },
    "eth:0x947Cb49334e6571ccBFEF1f1f1178d8469D65ec7": {
      "category": "core",
      "description": "Global configuration and role authority for the rsETH system. It controls supported assets, strategy mappings, protocol fees, and reward receiver routing.",
      "fields": {
        "$admin": {
          "severity": "HIGH",
          "type": "CODE_CHANGE",
          "description": "Proxy admin that can upgrade the LRTConfig implementation.",
          "permissions": [{ "type": "upgrade" }]
        },
        "protocolFeeInBPS": {
          "severity": "HIGH",
          "type": "RISK_PARAMETER",
          "description": "Protocol fee in basis points applied by the rsETH system."
        },
        "eigenLayerRewardReceiver": {
          "severity": "HIGH",
          "type": "PERMISSION",
          "description": "Address receiving EigenLayer-side rewards for the rsETH system.",
          "permissions": [
            {
              "type": "interact",
              "description": "receive and route EigenLayer reward flows that affect protocol value accrual."
            }
          ]
        }
      }
    },
    "eth:0x036676389e48133B63a802f8635AD39E752D375D": {
      "category": "core",
      "description": "Main deposit pool that accepts ETH/LST deposits, mints rsETH, and routes collateral into NodeDelegators and EigenLayer strategies.",
      "fields": {
        "$admin": {
          "severity": "HIGH",
          "type": "CODE_CHANGE",
          "description": "Proxy admin that can upgrade the LRTDepositPool implementation.",
          "permissions": [{ "type": "upgrade" }]
        },
        "lrtConfig": {
          "severity": "HIGH",
          "type": ["PERMISSION", "EXTERNAL"],
          "description": "External role authority that gates privileged deposit pool operations.",
          "permissions": [
            {
              "type": "interact",
              "description": "change role-gated deposit pool behavior including pausing, node delegator queue management, and collateral movement controls."
            }
          ]
        },
        "maxNodeDelegatorLimit": {
          "severity": "HIGH",
          "type": "RISK_PARAMETER",
          "description": "Upper bound on active NodeDelegator contracts used to route collateral to EigenLayer."
        },
        "getETHDistributionData": {
          "severity": "HIGH",
          "type": "RISK_PARAMETER",
          "description": "Live collateral breakdown including ETH staked in EigenLayer and ETH pending unstake."
        }
      }
    },
    "eth:0xb61e0E39b6d4030C36A176f576aaBE44BF59Dc78": {
      "category": "gov",
      "canActIndependently": false,
      "description": "Shared ProxyAdmin controlling upgrades for rsETH core contracts and NodeDelegator proxies.",
      "fields": {
        "owner": {
          "severity": "HIGH",
          "type": "PERMISSION",
          "description": "ProxyAdmin owner that can execute upgrades across the rsETH core proxy set.",
          "permissions": [{ "type": "act" }]
        }
      }
    },
    "eth:0x49bD9989E31aD35B0A62c20BE86335196A3135B1": {
      "category": "gov",
      "description": "Timelock owner of the shared ProxyAdmin for rsETH core contracts.",
      "fields": {
        "getMinDelay": {
          "severity": "HIGH",
          "type": "RISK_PARAMETER",
          "description": "Execution delay applied to queued timelock operations."
        }
      }
    },
    "eth:0xb3696a817D01C8623E66D156B6798291fa10a46d": {
      "category": "gov",
      "description": "Primary custody multisig used by the rsETH system.",
      "fields": {
        "$threshold": {
          "severity": "HIGH",
          "type": "PERMISSION",
          "description": "Custody multisig signing threshold."
        }
      }
    },
    "eth:0xc02Ab410f0734EFa3F14628780e6e695156024C2": {
      "fields": {
        "dvnConfig_rsETH_OFTAdapter_fromUnichain30320": {
          "description": "DVN setup used by rsETH OFTAdapter for inbound messages from Unichain (eid 30320).",
          "handler": {
            "type": "call",
            "method": "getUlnConfig",
            "args": ["0x85d456B2DfF1fd8245387C0BfB64Dfb700e98Ef3", 30320]
          }
        },
        "totalDVNs_rsETH_OFTAdapter_fromUnichain30320": {
          "description": "Total DVN count for this lane. (equals required count while optionalDVNCount is 0)",
          "handler": {
            "type": "call",
            "method": "getUlnConfig",
            "args": ["0x85d456B2DfF1fd8245387C0BfB64Dfb700e98Ef3", 30320]
          },
          "edit": ["get", "requiredDVNCount"]
        }
      }
    },
    "unichain:0xe1844c5D63a9543023008D332Bd3d2e6f1FE1043": {
      "fields": {
        "dvnConfig_rsETH_OFT_fromEthereum30101": {
          "description": "DVN setup used by rsETH OFT for inbound messages from Ethereum (eid 30101).",
          "handler": {
            "type": "call",
            "method": "getUlnConfig",
            "args": ["0xc3eACf0612346366Db554C991D7858716db09f58", 30101]
          }
        },
        "totalDVNs_rsETH_OFT_fromEthereum30101": {
          "description": "Total DVN count for this lane. (equals required count while optionalDVNCount is 0)",
          "handler": {
            "type": "call",
            "method": "getUlnConfig",
            "args": ["0xc3eACf0612346366Db554C991D7858716db09f58", 30101]
          },
          "edit": ["get", "requiredDVNCount"]
        }
      }
    },
    "unichain:0xc3eACf0612346366Db554C991D7858716db09f58": {
      "category": "core",
      "description": "Unichain LayerZero OFT representation of rsETH, controlled by its owner safe and LayerZero endpoint wiring.",
      "ignoreInWatchMode": ["totalSupply"],
      "fields": {
        "ethereumPeer": {
          "description": "LayerZero peer configured for Ethereum (eid 30101).",
          "handler": {
            "type": "call",
            "method": "peers",
            "args": [30101]
          },
          "edit": ["format", "RsEthOftEthereumPeer"]
        },
        "owner": {
          "severity": "HIGH",
          "type": "PERMISSION",
          "description": "Owner safe that can configure LayerZero OFT settings on Unichain.",
          "permissions": [{ "type": "interact" }]
        },
        "$tokenData": {
          "handler": {
            "type": "ERC20Data",
            "overrides": {
              "source": "external",
              "supply": "totalSupply",
              "category": "ether",
              "coingeckoId": "kelp-dao-restaked-eth",
              "bridgedUsing": {
                "bridges": [
                  {
                    "name": "Layer Zero v2 OFT",
                    "slug": "layerzerov2oft"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
