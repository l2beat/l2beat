    // PoolInstance — main market
    "eth:0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2": {
      "ignoreInWatchMode": ["getReservesCount", "MAX_NUMBER_RESERVES", "POOL_REVISION", "UMBRELLA"]
    },
    // RewardsController — main market
    "eth:0x8164Cc65827dcFe994AB23944CBC90e0aa80bFcb": {
      "ignoreInWatchMode": ["REVISION"]
    },
    // RewardsController — Horizon RWA market
    "eth:0x1D5D386a90CEA8AcEa9fa75389e97CF5F1AE21D3": {
      "ignoreInWatchMode": ["REVISION"]
    },
    // VariableDebtTokenMainnetInstanceGHO
    "eth:0x786dBff3f1292ae8F92ea68Cf93c30b34B1ed04B": {
      "ignoreInWatchMode": [
        "DEBT_TOKEN_REVISION",
        "decimals",
        "DELEGATION_WITH_SIG_TYPEHASH",
        "DOMAIN_SEPARATOR",
        "EIP712_REVISION",
        "name",
        "scaledTotalSupply",
        "symbol",
        "totalSupply"
      ]
    },
    // Horizon RWA aToken proxies — discovered via getAllATokens on provider 0x53519c32...
