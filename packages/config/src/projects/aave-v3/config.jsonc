    "eth:0xdAbad81aF85554E9ae636395611C58F7eC1aAEc5": {
      "ignoreInWatchMode": [
        "getPayloadsCount"
      ]
    },
    // PoolConfigurator entries: each market's PoolConfigurator gets its
    // own market's Pool/AaveOracle/ACLManager pinned as discovered fields
    // so the call-graph 1-hop DiscoveredValuesScan resolver finds the right
    // targets. Without these, the only Pool-shaped value on a PoolConfigurator
    // is `proxyAdmin`, which is the immutable PAP that DEPLOYED the contract
    // — not always the same as the runtime PAP (Horizon's proxyAdmin is the
    // Lido PAP), so the resolver mis-routes calls into the wrong market.
    // marketPool/marketAaveOracle/marketAclManager are deliberately generic
    // names so the same field appears on every market.
    "eth:0x342631c6CeFC9cfbf97b2fe4aa242a236e1fd517": {
      "ignoreInWatchMode": [
        "CONFIGURATOR_REVISION",
        "marketAaveOracle",
        "marketAclManager",
        "marketPool"
      ],
      "fields": {
        "proxyAdmin": {
          "description": "Immutable admin of InitializableImmutableAdminUpgradeabilityProxy. PoolAddressesProvider deployed this PoolConfigurator. The EIP-1967 admin slot reads zero on these proxies because the admin lives in a Solidity immutable, not the EIP-1967 slot.",
          "handler": {
            "type": "hardcoded",
            "value": "eth:0x5D39E06b825C1F2B80bf2756a73e28eFAA128ba0"
          }
        },
        "marketPool": { "handler": { "type": "hardcoded", "value": "eth:0x4e033931ad43597d96D6bcc25c280717730B58B1" } },
        "marketAaveOracle": { "handler": { "type": "hardcoded", "value": "eth:0xE3C061981870C0C7b1f3C4F4bB36B95f1F260BE6" } },
        "marketAclManager": { "handler": { "type": "hardcoded", "value": "eth:0x013E2C7567b6231e865BB9273F8c7656103611c0" } }
      }
    },
