    "eth:0x30D20208d987713f46DFD34EF128Bb16C404D10f": {
      "ignoreDiscovery": true
    },
    // 1INCH Token — excluded because its on-chain `name()` "1INCH Token" starts with
    // a digit, producing an invalid Clingo identifier in permission modelling
