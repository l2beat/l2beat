{
  "$schema": "../../../../discovery/schemas/config.v2.schema.json",
  "name": "aave-v3",
  "import": ["../globalConfig.jsonc"],
  "initialAddresses": ["eth:0xbaA999AC55EAce41CcAE355c77809e68Bb345170"],
  "maxDepth": 8,
  "maxAddresses": 400,
  "overrides": {
    "eth:0x0a16f2FCC0D44FaE41cc54e079281D84A363bECD": {
      "ignoreMethods": ["getAllReservesTokens"]
    },
    "eth:0xbaA999AC55EAce41CcAE355c77809e68Bb345170": {
      "ignoreMethods": ["getAddressesProviderAddressById"]
    },
    "eth:0x7c8509591f9693D21280d96e149a08A3bf69Cd0c": {
      "ignoreMethods": ["getAllReservesTokens"],
      "ignoreInWatchMode": ["getDebtCeilingDecimals"]
    },
    "eth:0x0AA97c284e98396202b6A04024F5E2c65026F3c0": {
      "ignoreMethods": ["getReservesList"],
      "ignoreInWatchMode": ["getReservesCount", "MAX_NUMBER_RESERVES", "POOL_REVISION", "UMBRELLA"]
    },
    "eth:0x9AEE0B04504CeF83A65AC3f0e838D0593BCb2BC7": {
      "ignoreMethods": ["getProposal", "getProposalState"],
      "ignoreInWatchMode": [
        "getProposalsCount",
        "MIN_VOTING_DURATION",
        "NAME",
        "PRECISION_DIVIDER",
        "PROPOSAL_EXPIRATION_TIME"
      ]
    },
    "eth:0x4e033931ad43597d96D6bcc25c280717730B58B1": {
      "ignoreMethods": ["getReservesList"],
      "ignoreInWatchMode": [
        "getReservesCount",
        "MAX_NUMBER_RESERVES",
        "POOL_REVISION"
      ]
    },
    "eth:0xB85B2bFEbeC4F5f401dbf92ac147A3076391fCD5": {
      "ignoreMethods": ["getAllReservesTokens"]
    },
    // CrossChainControllerUpgradeRev3 — array overflow on chain-indexed getters
    "eth:0xEd42a7D8559a463722Ca4beD50E0Cc05a386b0e1": {
      "ignoreMethods": [
        "getConfigurationByChain",
        "getForwarderBridgeAdaptersByChain",
        "getOptimalBandwidthByChain",
        "getReceiverBridgeAdaptersByChain"
      ],
      "ignoreInWatchMode": ["getCurrentEnvelopeNonce", "getCurrentTransactionNonce"]
    },
    // SameChainAdapter — array overflow on chain ID lookups
    "eth:0x6cfbd2aA4691fc18B9C209bDd43DC3943C228FCf": {
      "ignoreMethods": [
        "getTrustedRemoteByChainId",
        "infraToNativeChainId",
        "nativeToInfraChainId"
      ]
    },
    // StakedAaveV3 — array overflow on index-based getters
    "eth:0x4da27a545c0c5B758a6BA100e3a049001de870f5": {
      "ignoreMethods": ["getAdmin", "getPendingAdmin", "previewRedeem", "previewStake"],
      "ignoreInWatchMode": [
        "decimals",
        "DELEGATE_BY_TYPE_TYPEHASH",
        "DELEGATE_TYPEHASH",
        "DOMAIN_SEPARATOR",
        "EIP712_REVISION",
        "eip712Domain",
        "EXCHANGE_RATE_UNIT",
        "INITIAL_EXCHANGE_RATE",
        "name",
        "PERMIT_TYPEHASH",
        "POWER_SCALE_FACTOR",
        "PRECISION",
        "REVISION",
        "symbol",
        "totalSupply"
      ]
    },
    // 4th PoolInstance — suppress large reserves list
    "eth:0xAe05Cd22df81871bc7cC2a04BeCfb516bFe332C8": {
      "ignoreMethods": ["getReservesList"],
      "ignoreInWatchMode": ["getReservesCount", "MAX_NUMBER_RESERVES", "POOL_REVISION", "UMBRELLA"]
    },
    // 4th AaveProtocolDataProvider — suppress reserve token enumeration
    "eth:0x53519c32f73fE1797d10210c4950fFeBa3b21504": {
      "ignoreMethods": ["getAllReservesTokens"]
    },
    // AaveEcosystemReserveV2
    "eth:0x25F2226B597E8F9514B3F68F00f494cF4f286491": {
      "ignoreInWatchMode": ["deltaOf", "getNextStreamId", "getStream", "REVISION"]
    },
    // CollectorWithCustomImpl
    "eth:0x464C71f6c2F760DdA6093dCB91C24c39e5d6e18c": {
      "ignoreInWatchMode": ["deltaOf", "getNextStreamId", "getStream"]
    },
    // Gho Token
    "eth:0x40D16FC0246aD3160Ccc09B8D0D3A2cD28aE6C2f": {
      "ignoreInWatchMode": ["totalSupply"]
    },
    // GnosisSafe (Aave Guardian)
    "eth:0xCe52ab41C40575B072A18C9700091Ccbe4A06710": {
      "ignoreInWatchMode": ["domainSeparator", "getChainId", "multisigThreshold", "nonce", "VERSION"]
    },
    // GnosisSafeL2 (BGD Labs Multisig)
    "eth:0x8513e6F37dBc52De87b166980Fa3F50639694B60": {
      "ignoreInWatchMode": ["domainSeparator", "getChainId", "multisigThreshold", "nonce", "VERSION"]
    },
    // PayloadsController
    "eth:0xdAbad81aF85554E9ae636395611C58F7eC1aAEc5": {
      "ignoreInWatchMode": ["getPayloadsCount"]
    },
    // PoolConfiguratorInstance — GHO/Lido market
    "eth:0x342631c6CeFC9cfbf97b2fe4aa242a236e1fd517": {
      "ignoreInWatchMode": ["CONFIGURATOR_REVISION"]
    },
    // PoolConfiguratorInstance — main market
    "eth:0x64b761D848206f447Fe2dd461b0c635Ec39EbB27": {
      "ignoreInWatchMode": ["CONFIGURATOR_REVISION"]
    },
    // PoolConfiguratorInstance — Horizon RWA market
    "eth:0x83Cb1B4af26EEf6463aC20AFbAC9c0e2E017202F": {
      "ignoreInWatchMode": ["CONFIGURATOR_REVISION"]
