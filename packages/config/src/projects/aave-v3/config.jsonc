{
  "$schema": "../../../../discovery/schemas/config.v2.schema.json",
  "name": "aave-v3",
  "import": [
    "../globalConfig.jsonc"
  ],
  "initialAddresses": [
    "eth:0xbaA999AC55EAce41CcAE355c77809e68Bb345170",
    // Pool 4 ("Aave Horizon") PoolAddressesProvider — not registered in the Registry
    // (Pool 4 was launched as a standalone product after the Registry was established)
    "eth:0x5D39E06b825C1F2B80bf2756a73e28eFAA128ba0",
    // Staked AAVE Safety Module — referenced by GovernancePowerStrategy but exceeds maxDepth
    // from the Registry chain; added explicitly so its admin roles are properly discovered.
    "eth:0x4da27a545c0c5B758a6BA100e3a049001de870f5"
  ],
  "maxDepth": 11,
  "maxAddresses": 600,
  "overrides": {
    "eth:0x0a16f2FCC0D44FaE41cc54e079281D84A363bECD": {
      "ignoreMethods": [
        "getAllReservesTokens"
      ],
      "ignoreInWatchMode": [
        "getDebtCeilingDecimals"
      ]
    },
    "eth:0xbaA999AC55EAce41CcAE355c77809e68Bb345170": {
      "ignoreMethods": [
        "getAddressesProviderAddressById"
      ]
    },
    "eth:0x7c8509591f9693D21280d96e149a08A3bf69Cd0c": {
      "ignoreMethods": [
        "getAllReservesTokens"
      ],
      "ignoreInWatchMode": [
        "getDebtCeilingDecimals"
      ]
    },
    "eth:0x0AA97c284e98396202b6A04024F5E2c65026F3c0": {
      "ignoreInWatchMode": [
        "getReservesCount",
        "MAX_NUMBER_RESERVES",
        "POOL_REVISION",
        "UMBRELLA"
      ],
      "fields": {
        "getAllVariableDebtTokens": {
          "handler": {
            "type": "aaveReserveTokens",
            "tokenType": "variableDebt"
          }
        },
        "proxyAdmin": {
          "description": "Immutable admin of InitializableImmutableAdminUpgradeabilityProxy. PoolAddressesProvider deployed this Pool. The EIP-1967 admin slot reads zero on these proxies because the admin lives in a Solidity immutable, not the EIP-1967 slot.",
          "handler": {
            "type": "hardcoded",
            "value": "eth:0xeBa440B438Ad808101d1c451C1C5322c90BEFCdA"
          }
        }
      }
    },
    "eth:0x9AEE0B04504CeF83A65AC3f0e838D0593BCb2BC7": {
      "ignoreMethods": [
        "getProposal",
        "getProposalState"
      ],
      "ignoreInWatchMode": [
        "getProposalsCount",
        "getVotingPortalsCount",
        "MIN_VOTING_DURATION",
        "NAME",
        "PRECISION_DIVIDER",
        "PROPOSAL_EXPIRATION_TIME"
      ]
    },
    "eth:0x4e033931ad43597d96D6bcc25c280717730B58B1": {
      "ignoreInWatchMode": [
        "getReservesCount",
        "MAX_NUMBER_RESERVES",
        "POOL_REVISION",
        "UMBRELLA"
      ],
      "fields": {
        "getAllVariableDebtTokens": {
          "handler": {
            "type": "aaveReserveTokens",
            "tokenType": "variableDebt"
          }
        },
        "proxyAdmin": {
          "description": "Immutable admin of InitializableImmutableAdminUpgradeabilityProxy. PoolAddressesProvider deployed this Pool. The EIP-1967 admin slot reads zero on these proxies because the admin lives in a Solidity immutable, not the EIP-1967 slot.",
          "handler": {
            "type": "hardcoded",
            "value": "eth:0xcfBf336fe147D643B9Cb705648500e101504B16d"
          }
        }
      }
    },
    "eth:0xB85B2bFEbeC4F5f401dbf92ac147A3076391fCD5": {
      "ignoreMethods": [
        "getAllReservesTokens"
      ],
      "ignoreInWatchMode": [
        "getDebtCeilingDecimals"
      ]
    },
    "eth:0xEd42a7D8559a463722Ca4beD50E0Cc05a386b0e1": {
      "ignoreMethods": [
        "getConfigurationByChain",
        "getOptimalBandwidthByChain"
      ],
      "ignoreInWatchMode": [
        "getCurrentEnvelopeNonce",
        "getCurrentTransactionNonce"
      ],
      "fields": {
        // Surface the per-chain bridge adapters (LayerZero / Hyperlane / CCIP / Wormhole)
        // that a.DI uses as the actual cross-chain transports. The methods take a chainId
        // arg, so discovery's auto-call won't enumerate them; we call explicitly per
        // supported chain (getSupportedChains() == [137, 43114] at time of writing).
        "receiverAdaptersPolygon": {
          "handler": {
            "type": "call",
            "method": "function getReceiverBridgeAdaptersByChain(uint256) view returns (address[])",
            "args": [137]
          }
        },
        "receiverAdaptersAvalanche": {
          "handler": {
            "type": "call",
            "method": "function getReceiverBridgeAdaptersByChain(uint256) view returns (address[])",
            "args": [43114]
          }
        },
        "forwarderAdaptersPolygon": {
          "handler": {
            "type": "call",
            "method": "function getForwarderBridgeAdaptersByChain(uint256) view returns (tuple(address destinationBridgeAdapter, address currentChainBridgeAdapter)[])",
            "args": [137]
          }
        },
        "forwarderAdaptersAvalanche": {
          "handler": {
            "type": "call",
            "method": "function getForwarderBridgeAdaptersByChain(uint256) view returns (tuple(address destinationBridgeAdapter, address currentChainBridgeAdapter)[])",
            "args": [43114]
          }
        }
      }
    },
    "eth:0x6cfbd2aA4691fc18B9C209bDd43DC3943C228FCf": {
      // SameChainAdapter — same-chain forwarding stub used by a.DI
      "ignoreMethods": [
        "getTrustedRemoteByChainId",
        "infraToNativeChainId",
        "nativeToInfraChainId"
      ]
    },
    // a.DI bridge adapters: keep them as leaves. Each adapter exposes
    // CROSS_CHAIN_CONTROLLER (Aave-internal, fine to traverse) plus a
    // pointer to an external bridge protocol (Polygon FxRoot / Chainlink
    // CCIP / LayerZero / Hyperlane). Block the external pointers here so
    // discovery doesn't walk into the bridge providers' infrastructure.
    "eth:0x1562F1b2487F892BBA8Ef325aF054Fd157510a71": {
      // PolygonAdapterEthereum (Polygon native PoS bridge transport)
      "ignoreRelatives": ["FX_TUNNEL"],
      "ignoreMethods": ["getTrustedRemoteByChainId"]
    },
    "eth:0xB7a6618df58626C3a122ABAFD6Ee63Af63f3Ef29": {
      // CCIPAdapter (Chainlink CCIP transport)
      "ignoreRelatives": ["CCIP_ROUTER", "LINK_TOKEN"],
      "ignoreMethods": ["getTrustedRemoteByChainId"]
    },
    "eth:0x8410d9BD353b420ebA8C48ff1B0518426C280FCC": {
      // LayerZeroAdapter (LayerZero V2 transport)
      "ignoreRelatives": ["LZ_ENDPOINT"],
      "ignoreMethods": ["getTrustedRemoteByChainId"]
    },
    "eth:0x01dcb90Cf13b82Cde4A0BAcC655585a83Af3cCC1": {
      // HyperLaneAdapter (Hyperlane mailbox transport)
      "ignoreRelatives": ["HL_MAIL_BOX"],
      "ignoreMethods": ["getTrustedRemoteByChainId"]
    },
    "eth:0x4da27a545c0c5B758a6BA100e3a049001de870f5": {
      "ignoreMethods": [
        "getPendingAdmin",
        "previewRedeem",
        "previewStake"
      ],
      "fields": {
        // Admin for SLASH_ADMIN_ROLE (role 0)
        "adminForSlash": {
          "handler": {
            "type": "call",
            "method": "getAdmin",
            "args": [
              0
            ]
          }
        },
        // Admin for COOLDOWN_ADMIN_ROLE (role 1)
        "adminForCooldown": {
          "handler": {
            "type": "call",
            "method": "getAdmin",
            "args": [
              1
            ]
          }
        },
        // Admin for CLAIM_HELPER_ROLE (role 2)
        "adminForClaimHelper": {
          "handler": {
            "type": "call",
            "method": "getAdmin",
            "args": [
              2
            ]
          }
        }
      },
      "ignoreInWatchMode": [
        "CLAIM_HELPER_ROLE",
        "COOLDOWN_ADMIN_ROLE",
        "decimals",
        "DELEGATE_BY_TYPE_TYPEHASH",
        "DELEGATE_TYPEHASH",
