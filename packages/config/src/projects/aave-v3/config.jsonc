    "eth:0x2f39d218133AFaB8F2B819B1066c7E434Ad94E9e": {
      "ignoreInWatchMode": [
        "getMarketId",
        "collectorBalanceUsd",
        "totalCollateralUsd"
      ],
      "fields": {
        // Fetch the Umbrella address stored under the generic getAddress(bytes32) slot.
        // UMBRELLA = bytes32('UMBRELLA') = 0x554d4252454c4c41...
        // Using full ABI signature so getFunctionFragment parses it directly (no ABI search needed).
        "getUmbrella": {
          "handler": {
            "type": "call",
            "method": "function getAddress(bytes32 id) external view returns (address)",
            "args": [
              "0x554d4252454c4c41000000000000000000000000000000000000000000000000"
            ]
          }
        },
        // Aave Collector treasury size in USD: sum of aToken.balanceOf(Collector)
        // × oracle price across every reserve in the main Aave V3 Ethereum market.
        // Used as the structural cap for guardian/owner-callable steward
        // functions (PoolExposureSteward) that route Collector funds between
        // governance-approved Aave pools — funds never leave the Collector,
        // so this aggregate bounds the worst-case fund impact.
        "collectorBalanceUsd": {
          "handler": {
            "type": "aaveMarketAggregateTvs",
            "balanceOfAddress": "eth:0x464C71f6c2F760DdA6093dCB91C24c39e5d6e18c"
          }
        },
        // Whole-market TVS in USD: sum of aToken.totalSupply × oracle price.
        // Used as the structural cap for emergency-pause functions on this
        // market's PoolConfigurator — pausing a whole pool freezes (but does
        // not extract) the entire market's deposits, so the worst-case
        // operational impact is bounded by the live market TVS.
        "totalCollateralUsd": {
          "handler": {
            "type": "aaveMarketAggregateTvs"
          }
        }
      }
    },
    "eth:0xcfBf336fe147D643B9Cb705648500e101504B16d": {
      "ignoreInWatchMode": [
        "getMarketId",
        "totalCollateralUsd"
      ],
      "fields": {
        "getUmbrella": {
          "handler": {
            "type": "call",
            "method": "function getAddress(bytes32 id) external view returns (address)",
            "args": [
              "0x554d4252454c4c41000000000000000000000000000000000000000000000000"
            ]
          }
        },
        "totalCollateralUsd": {
          "handler": {
            "type": "aaveMarketAggregateTvs"
          }
        }
      }
    },
