    // --- AaveOracle instances — surface per-asset price source map via AssetSourceUpdated events.
    //     Returns { asset → source } pairs; both sides become discovery relatives, landing each underlying
    //     token AND each price feed as a leaf node (each pruned via its own `ignoreRelatives` override below).
    "eth:0x43b64f28A678944E0655404B0B98E443851cC34F": {
      "ignoreInWatchMode": [
        "BASE_CURRENCY_UNIT",
        "marketPool"
      ],
      "fields": {
        "assetSources": {
          "handler": {
            "type": "event",
            "select": "source",
            "groupBy": "asset",
            "set": { "event": "event AssetSourceUpdated(address indexed asset, address indexed source)" }
          }
        },
        "marketPool": { "handler": { "type": "hardcoded", "value": "eth:0x0AA97c284e98396202b6A04024F5E2c65026F3c0" } }
      }
    },
