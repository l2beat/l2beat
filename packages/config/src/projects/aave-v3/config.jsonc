    // aHorRwaJAAA, aHorRwaVBILL, aHorRwaACRED — templates auto-apply ignoreInWatchMode
    // Underlying RWA token contracts for the Horizon market (external protocols: Ondo, JTRSY, etc.)
    // USTB, USCC, USYC, JTRSY, JAAA, VBILL, ACRED underlying tokens — not part of Aave scope
    "eth:0x43415eB6ff9DB7E26A15b704e7A3eDCe97d31C4e": { "ignoreDiscovery": true },
    "eth:0x14d60E7FDC0D71d8611742720E4C50E7a974020c": { "ignoreDiscovery": true },
