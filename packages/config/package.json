{
  "name": "@l2beat/config",
  "version": "0.1.0",
  "private": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -f build/db.sqlite && node build/build.js",
    "build:dependencies": "cd ../.. && pnpm build:dependencies:config",
    "watch:dependencies": "cd ../.. && pnpm watch:dependencies:config",
    "clean": "rm -rf build *.tsbuildinfo",
    "format:fix": "biome format --write .",
    "format": "biome format .",
    "lint:fix": "biome check --formatter-enabled=false --write .",
    "lint": "biome check --formatter-enabled=false .",
    "test": "mocha",
    "typecheck": "tsc --noEmit",
    "get-lz-data": "tsx scripts/omnichain/index.ts",
    "update-multichain": "tsx scripts/multichain/index.ts",
    "socket-crawl": "tsx scripts/socketcrawl",
    "socket-convert": "tsx scripts/socketconvert",
    "fill-ts": "tsx scripts/fillts/index.ts",
    "tokens": "tsx scripts/tokens/tokens.ts",
    "tokens:verify": "sh scripts/tokens/verify.sh",
    "tokens:generate-names": "tsx scripts/tokens/generateTokenNames.ts",
    "coingecko:platforms": "tsx scripts/getCoingeckoPlatforms.ts",
    "stargatev2-pools": "tsx scripts/stargatev2-pools/index.ts",
    "diff": "./scripts/diff/diff.sh",
    "tvs:update-schema": "tsx ./scripts/tvs/update-schema.ts"
  },
  "dependencies": {
    "@l2beat/discovery": "workspace:*",
    "@l2beat/shared-pure": "workspace:*",
    "ethers": "^5.7.2",
    "lodash": "^4.17.21",
    "sqlite3": "5.1.7"
  },
  "devDependencies": {
    "@l2beat/validate": "workspace:*",
    "@l2beat/backend-tools": "workspace:*",
    "@l2beat/shared": "workspace:*",
    "@l2beat/typescript-config": "workspace:*",
    "@types/diff": "^7.0.2",
    "@types/lodash": "^4.17.12",
    "@types/node-fetch": "^2.6.11",
    "alpinejs": "^3.14.9",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.11",
    "diff": "^7.0.0",
    "dotenv": "^16.4.5",
    "node-fetch": "^2.6.7",
    "tsx": "^4.9.3"
  }
}
