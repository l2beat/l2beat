{
  "name": "l2beat",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "^22.0.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "pnpm": {
    "overrides": {
      "form-data@^2": "2.5.4",
      "form-data@^4": "4.0.4"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "build:backend": "turbo run build --filter=@l2beat/backend",
    "build:frontend": "turbo run build --filter=@l2beat/frontend",
    "build:frontend-ci": "turbo run build --cache local:rw,remote:r --summarize --filter=@l2beat/frontend",
    "build:tools-api": "turbo run build --filter=@l2beat/tools-api",
    "build:public-api": "turbo run build --filter=@l2beat/public-api",
    "build:protocolbeat": "turbo run build --filter=@l2beat/protocolbeat",
    "build:tools": "turbo run build --filter=@l2beat/tools",
    "build:token-backend": "turbo run build --filter=@l2beat/token-backend",
    "build:uops-dashboard": "turbo run build --filter=@l2beat/uops-dashboard",
    "build:dependencies": "turbo run build --filter=@l2beat/frontend^... --filter=@l2beat/backend^... --filter=@l2beat/tools-api --filter=@l2beat/l2b",
    "build:dependencies:frontend": "turbo run build --filter=@l2beat/frontend^...",
    "build:dependencies:backend": "turbo run build --filter=@l2beat/backend^...",
    "build:dependencies:l2b": "turbo run build --filter=@l2beat/l2b^...",
    "build:dependencies:discovery": "turbo run build --filter=@l2beat/discovery^...",
    "build:dependencies:config": "turbo run build --filter=@l2beat/config^...",
    "build:dependencies:public-api": "turbo run build --filter=@l2beat/public-api^...",
    "build:dependencies:token-backend": "turbo run build --filter=@l2beat/token-backend^...",
    "build:dependencies:token-ui": "turbo run build --filter=@l2beat/token-ui^...",
    "build:dependencies:backoffice": "turbo run build --filter=@l2beat/backoffice^...",
    "watch:dependencies": "turbo watch build --filter=@l2beat/frontend^... --filter=@l2beat/backend^... --filter=@l2beat/tools-api --filter=@l2beat/l2b",
    "watch:dependencies:frontend": "turbo watch build --filter=@l2beat/frontend^...",
    "watch:dependencies:backend": "turbo watch build --filter=@l2beat/backend^...",
    "watch:dependencies:l2b": "turbo watch build --filter=@l2beat/l2b^...",
    "watch:dependencies:discovery": "turbo watch build --filter=@l2beat/discovery^...",
    "watch:dependencies:config": "turbo watch build --filter=@l2beat/config^...",
    "watch:dependencies:public-api": "turbo watch build --filter=@l2beat/public-api^...",
    "watch:dependencies:token-backend": "turbo watch build --filter=@l2beat/token-backend^...",
    "watch:dependencies:backoffice": "turbo watch build --filter=@l2beat/backoffice^...",
    "dev:bo": "pnpm -C packages/backoffice dev:bo",
    "clean": "turbo run clean",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome check --formatter-enabled=false .",
    "lint:fix": "biome check --formatter-enabled=false --write .",
    "start": "cd packages/backend && pnpm start",
    "test": "turbo run test -- --reporter progress",
    "test:exclude-backend": "turbo run test --filter=!@l2beat/backend --filter=!@l2beat/database",
    "typecheck": "turbo run typecheck",
    "ci:check": "turbo run ci:check",
    "heroku-postbuild": "pnpm build:backend && pnpm install --production",
    "checkout": "pnpm clean && pnpm && pnpm build",
    "coolify:check-env": "node -r esbuild-register scripts/coolify/check-env.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@l2beat/validate": "workspace:*",
    "@sinonjs/fake-timers": "^11.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.16",
    "@types/sinonjs__fake-timers": "^8.1.2",
    "cmd-ts": "^0.13.0",
    "dotenv": "^16.4.5",
    "earl": "^1.1.0",
    "esbuild": "^0.25.1",
    "esbuild-register": "^3.6.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.1",
    "turbo": "^2.9.6",
    "typescript": "^5.5.3",
    "wait-for-expect": "^3.0.2"
  }
}
